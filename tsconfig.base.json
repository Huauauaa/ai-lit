{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "noEmit": true,
    "declaration": false,
    "types": [],
    "resolveJsonModule": true,
    "isolatedModules": true
  }
}
