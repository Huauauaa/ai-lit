{
  "name": "@ai-lit/ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./style.css": "./dist/style.css",
    "./dist/*": "./dist/*"
  },
  "sideEffects": [
    "./dist/style.css",
    "./dist/config.js",
    "./dist/config.cjs"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build -c vite.config.config.ts && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"(skip) no lint configured\""
  },
  "dependencies": {
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "happy-dom": "^20.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
